{
	"name": "rustautomator",
	"displayName": "RustAutomator",
	"description": "Boost your Rust productivity by automating tedious boilerplate",
	"version": "0.2.0",
	"publisher": "kavindarathnayake",
	"license": "MIT",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Other"
	],
	"keywords": [
		"rust",
		"productivity",
		"automation"
	],
	"icon": "icon.png",
	"repository": {
		"url": "https://github.com/kavinda-100/rustautomator"
	},
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "rust-mod-automator.createRustModule",
				"title": "Create Rust Module Folder"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "rust-mod-automator.createRustModule",
					"when": "explorerResourceIsFolder && resourceFilename == src",
					"group": "navigation"
				}
			]
		},
		"snippets": [
			{
				"language": "rust",
				"path": "./snippets/rust-snippets.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/vscode": "^1.110.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"typescript-eslint": "^8.56.1",
		"eslint": "^9.39.3",
		"typescript": "^5.9.3",
		"ts-loader": "^9.5.4",
		"webpack": "^5.105.3",
		"webpack-cli": "^6.0.1",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2"
	}
}
